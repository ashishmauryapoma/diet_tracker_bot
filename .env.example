# =============================================================================
# Diet Tracker Bot — Environment Variables
# =============================================================================
# Copy this file to ".env" for local development.
# On Render, paste each key-value pair into the "Environment" tab of your
# Web Service — no .env file is needed on the server.
#
# To find values for the GOOGLE_* variables open your service-account JSON
# file and copy the matching fields (see README → "Google Setup" section).
# =============================================================================


# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot with @BotFather → /newbot → copy the token it gives you.
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceWithYourOwn

# The password the authorized user must type after /start (min 4 chars).
AUTH_PASSWORD=change-this-password


# ── Render / Webhook ──────────────────────────────────────────────────────────
# Set WEBHOOK_URL to your Render service URL for production webhook mode.
# Leave it EMPTY (or omit it) for local polling mode.
# Render injects PORT automatically — you normally do NOT need to set it.
#
# Example:   WEBHOOK_URL=https://diet-tracker-bot.onrender.com
WEBHOOK_URL=
# PORT is injected by Render — only set manually if testing webhooks locally.
# PORT=8443


# ── Groq AI ──────────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
# Model to use for nutrition analysis (any Groq-hosted model).
GROQ_MODEL=llama-3.3-70b-versatile


# ── Google Sheets ─────────────────────────────────────────────────────────────
# NO JSON FILE NEEDED — paste the values from your service-account JSON here.
#
# How to get these values:
#   1. Go to https://console.cloud.google.com → IAM → Service Accounts
#   2. Create / open a service account → Keys tab → Add Key → JSON
#   3. Open the downloaded JSON and copy each field below.
#
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_PRIVATE_KEY_ID=abc123def456
# Paste the FULL private key including -----BEGIN / -----END lines.
# Use \n for newlines (this is how the JSON file stores them).
GOOGLE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=123456789012345678901
GOOGLE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com

# The Google Sheet to write to.
# Use the ID from the sheet's URL (preferred):
#   https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=
# Or use the exact title of the sheet (only if GOOGLE_SHEET_ID is blank):
GOOGLE_SHEET_NAME=Diet Tracker


# ── App Behaviour ─────────────────────────────────────────────────────────────
# IANA timezone — used for "today", reminder times, and all timestamps.
APP_TIMEZONE=Asia/Kolkata

# Daily targets shown in /summary and fed to /analyze.
DAILY_WATER_GOAL_ML=3000
DAILY_CALORIE_GOAL=2000


# ── Reliability ───────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2


# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# On Render, logs go to stdout only (no persistent disk).
# Locally they also go to this rotating file.
LOG_FILE=logs/bot.log
